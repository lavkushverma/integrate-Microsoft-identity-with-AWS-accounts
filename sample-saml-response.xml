<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  SAMPLE SAML RESPONSE
  This is what Azure AD sends to AWS after successful authentication
  Use this for troubleshooting and understanding the SAML flow
-->

<samlp:Response xmlns:samlp="urn:oasis:names:tc:SAML:2.0:protocol" 
                ID="_abc12345-6789-0def-1234-567890abcdef"
                Version="2.0"
                IssueInstant="2024-01-15T10:30:00.000Z"
                Destination="https://signin.aws.amazon.com/saml"
                Consent="urn:oasis:names:tc:SAML:2.0:consent:unspecified">
  
  <!-- ISSUER: Azure AD Tenant -->
  <Issuer xmlns="urn:oasis:names:tc:SAML:2.0:assertion">
    https://sts.windows.net/a1b2c3d4-e5f6-7890-abcd-ef1234567890/
  </Issuer>
  
  <!-- STATUS: Success or Failure -->
  <samlp:Status>
    <samlp:StatusCode Value="urn:oasis:names:tc:SAML:2.0:status:Success"/>
  </samlp:Status>
  
  <!-- ASSERTION: Main authentication data -->
  <Assertion xmlns="urn:oasis:names:tc:SAML:2.0:assertion"
             ID="_1234abcd-5678-90ef-1234-567890abcdef"
             IssueInstant="2024-01-15T10:30:00.000Z"
             Version="2.0">
    
    <Issuer>https://sts.windows.net/a1b2c3d4-e5f6-7890-abcd-ef1234567890/</Issuer>
    
    <!-- DIGITAL SIGNATURE (validates this came from Azure AD) -->
    <Signature xmlns="http://www.w3.org/2000/09/xmldsig#">
      <SignedInfo>
        <CanonicalizationMethod Algorithm="http://www.w3.org/2001/10/xml-exc-c14n#"/>
        <SignatureMethod Algorithm="http://www.w3.org/2001/04/xmldsig-more#rsa-sha256"/>
        <Reference URI="#_1234abcd-5678-90ef-1234-567890abcdef">
          <Transforms>
            <Transform Algorithm="http://www.w3.org/2000/09/xmldsig#enveloped-signature"/>
            <Transform Algorithm="http://www.w3.org/2001/10/xml-exc-c14n#"/>
          </Transforms>
          <DigestMethod Algorithm="http://www.w3.org/2001/04/xmlenc#sha256"/>
          <DigestValue>base64encodeddigestvalue==</DigestValue>
        </Reference>
      </SignedInfo>
      <SignatureValue>base64encodedsignaturevalue==</SignatureValue>
      <KeyInfo>
        <X509Data>
          <X509Certificate>
            MIIDPjCCAiqgAwIBAgIQVWmXY/+9RqFA/OG9kFulHDAJBgUrDgMCHQUAMC0xKzAp
            BgNVBAMTImFjY291bnRzLmFjY2Vzc2NvbnRyb2wud2luZG93cy5uZXQwHhcNMjMw
            <!-- Certificate data -->
          </X509Certificate>
        </X509Data>
      </KeyInfo>
    </Signature>
    
    <!-- SUBJECT: Who is being authenticated -->
    <Subject>
      <NameID Format="urn:oasis:names:tc:SAML:1.1:nameid-format:persistent">
        john.doe@company.com
      </NameID>
      <SubjectConfirmation Method="urn:oasis:names:tc:SAML:2.0:cm:bearer">
        <SubjectConfirmationData 
          InResponseTo="_original-request-id"
          NotOnOrAfter="2024-01-15T11:30:00.000Z"
          Recipient="https://signin.aws.amazon.com/saml"/>
      </SubjectConfirmation>
    </Subject>
    
    <!-- CONDITIONS: When is this assertion valid -->
    <Conditions NotBefore="2024-01-15T10:25:00.000Z"
                NotOnOrAfter="2024-01-15T11:30:00.000Z">
      <AudienceRestriction>
        <Audience>https://signin.aws.amazon.com/saml</Audience>
      </AudienceRestriction>
    </Conditions>
    
    <!-- ATTRIBUTES: User and role information -->
    <AttributeStatement>
      
      <!-- 
        CRITICAL ATTRIBUTE 1: AWS Role
        Format: {role-arn},{provider-arn}
        This tells AWS which role to assume
      -->
      <Attribute Name="https://aws.amazon.com/SAML/Attributes/Role">
        <AttributeValue>
          arn:aws:iam::123456789012:role/Azure-Admin-Role,arn:aws:iam::123456789012:saml-provider/AzureAD
        </AttributeValue>
        <!-- If user has multiple roles, there will be multiple AttributeValue elements -->
      </Attribute>
      
      <!-- 
        CRITICAL ATTRIBUTE 2: Role Session Name
        This appears in CloudTrail logs
        Usually the user's email or employee ID
      -->
      <Attribute Name="https://aws.amazon.com/SAML/Attributes/RoleSessionName">
        <AttributeValue>john.doe@company.com</AttributeValue>
      </Attribute>
      
      <!-- 
        OPTIONAL ATTRIBUTE 3: Session Duration
        How long the AWS session lasts (in seconds)
        Max: 43200 (12 hours)
      -->
      <Attribute Name="https://aws.amazon.com/SAML/Attributes/SessionDuration">
        <AttributeValue>28800</AttributeValue> <!-- 8 hours -->
      </Attribute>
      
      <!-- 
        OPTIONAL: Additional user attributes
        These can be used for auditing but not required by AWS
      -->
      <Attribute Name="http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress">
        <AttributeValue>john.doe@company.com</AttributeValue>
      </Attribute>
      
      <Attribute Name="http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name">
        <AttributeValue>John Doe</AttributeValue>
      </Attribute>
      
      <Attribute Name="http://schemas.xmlsoap.org/ws/2005/05/identity/claims/givenname">
        <AttributeValue>John</AttributeValue>
      </Attribute>
      
      <Attribute Name="http://schemas.xmlsoap.org/ws/2005/05/identity/claims/surname">
        <AttributeValue>Doe</AttributeValue>
      </Attribute>
      
      <Attribute Name="http://schemas.microsoft.com/identity/claims/tenantid">
        <AttributeValue>a1b2c3d4-e5f6-7890-abcd-ef1234567890</AttributeValue>
      </Attribute>
      
      <Attribute Name="http://schemas.microsoft.com/identity/claims/objectidentifier">
        <AttributeValue>00000000-1111-2222-3333-444444444444</AttributeValue>
      </Attribute>
      
      <Attribute Name="http://schemas.microsoft.com/identity/claims/displayname">
        <AttributeValue>John Doe</AttributeValue>
      </Attribute>
      
      <Attribute Name="http://schemas.microsoft.com/claims/authnmethodsreferences">
        <AttributeValue>http://schemas.microsoft.com/claims/multipleauthn</AttributeValue>
        <AttributeValue>http://schemas.microsoft.com/claims/authnmethodspwd</AttributeValue>
      </Attribute>
      
    </AttributeStatement>
    
    <!-- AUTHENTICATION STATEMENT: How the user authenticated -->
    <AuthnStatement AuthnInstant="2024-01-15T10:30:00.000Z" 
                   SessionIndex="_session-index-value">
      <AuthnContext>
        <AuthnContextClassRef>
          urn:oasis:names:tc:SAML:2.0:ac:classes:PasswordProtectedTransport
        </AuthnContextClassRef>
      </AuthnContext>
    </AuthnStatement>
    
  </Assertion>
  
</samlp:Response>

<!--
  NOTES:
  
  1. This SAML response is base64 encoded when sent from Azure AD to AWS
  2. AWS validates the signature using the certificate from Azure AD metadata
  3. AWS checks the Audience value matches exactly: https://signin.aws.amazon.com/saml
  4. AWS extracts the Role attribute to determine which IAM role to assume
  5. AWS creates temporary credentials valid for SessionDuration seconds
  
  COMMON ISSUES:
  
  - Missing Role attribute → User cannot select a role
  - Wrong Role format → "Failed to assume role" error
  - Expired certificate → "Invalid SAML response" error
  - Wrong Audience → "Invalid SAML response" error
  - SessionDuration > role max → Uses role max instead
-->
